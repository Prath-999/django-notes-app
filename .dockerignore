# Ignore Git
.git
.gitignore

# Ignore environment files
.env
*.env

# Ignore Python cache
__pycache__/
*.pyc
*.pyo

# Ignore logs
*.log

# Ignore local database / volumes (VERY IMPORTANT)
data/
mysql/
db.sqlite3

# Ignore Docker files (optional)
docker-compose.yml
docker-compose.override.yml

# Ignore node_modules if present
node_modules/

# Ignore system files
.DS_Store
Thumbs.db
